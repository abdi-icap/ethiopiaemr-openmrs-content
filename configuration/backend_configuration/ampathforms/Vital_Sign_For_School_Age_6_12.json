            {
              "label": "Pulse",
              "type": "obs",
              "required": false,
              "id": "schoolAgePulse",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range for school-age children: 70-110 bpm",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 110.5 || myValue < 69.5)",
                "message": "Pulse is out of range (Normal range 70-110)"
              }
            }
          ]
        },
        {
          "label": "Blood Pressure",
          "isExpanded": "true",
          "questions": [
