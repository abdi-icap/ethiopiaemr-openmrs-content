              "validators": []
            },
            {
              "label": "BMI (Kg/m2)",
              "type": "obs",
              "required": false,
              "id": "schoolAgeBMI",
              "questionOptions": {
                "rendering": "number",
                "concept": "1342AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "calculate": {
