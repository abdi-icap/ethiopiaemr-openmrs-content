                "min": "0",
                "max": "100"
              },
              "questionInfo": "Normal: ≥90%",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && myValue < 89.5",
                "message": "Oxygen Saturation is out of range (Normal range ≥90)"
