      "label": "Vital Sign For Adolescents (above 12)",
      "sections": [
        {
          "label": "Pulse Rate",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Pulse",
              "type": "obs",
              "required": false,
              "id": "adolescentPulse",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range for adolescents: 60-100 bpm",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 100.5 || myValue < 59.5)",
                "message": "Pulse is out of range (Normal range 60-100)"
              }
            }
          ]
        },
        {
          "label": "Blood Pressure",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Systolic",
              "type": "obs",
              "required": false,
              "id": "adolescentSystolic",
              "questionOptions": {
                "rendering": "number",
                "concept": "5085AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range for adolescents: 90-140 mmHg",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 140.5 || myValue < 89.5)",
                "message": "Systolic is out of range (Normal range 90-140)"
              }
            },
            {
              "label": "Diastolic",
              "type": "obs",
              "required": false,
              "id": "adolescentDiastolic",
              "questionOptions": {
                "rendering": "number",
                "concept": "5086AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range for adolescents: 60-90 mmHg",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 90.5 || myValue < 59.5)",
                "message": "Diastolic is out of range (Normal range 60-90)"
              }
            },
            {
              "label": "Posture",
              "type": "obs",
              "required": false,
              "id": "adolescentPosture",
              "questionOptions": {
                "rendering": "radio",
                "concept": "159633AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "answers": [
                  {
                    "label": "Sitting",
                    "concept": "159630AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
                  },
                  {
                    "label": "Supine",
                    "concept": "159629AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
                  }
                ]
              }
            }
          ]
        },
        {
          "label": "Vitals",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Temperature",
              "type": "obs",
              "required": false,
              "id": "adolescentTemperature",
              "questionOptions": {
                "rendering": "number",
                "concept": "5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "25",
                "max": "43"
              },
              "questionInfo": "Normal range: 36.5-37.5°C",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 38.0 || myValue < 36.0)",
                "message": "Temperature is out of range (Normal range 36.5-37.5)"
              }
            },
            {
              "label": "Respiratory Rate",
              "type": "obs",
              "required": false,
              "id": "adolescentRespiratoryRate",
              "questionOptions": {
                "rendering": "number",
                "concept": "5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range for adolescents: 12-20 breaths/min",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 20.5 || myValue < 11.5)",
                "message": "Respiratory Rate is out of range (Normal range 12-20)"
              }
            },
            {
              "label": "SPO2",
              "type": "obs",
              "required": false,
              "id": "adolescentSPO2",
              "questionOptions": {
                "concept": "5092AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
