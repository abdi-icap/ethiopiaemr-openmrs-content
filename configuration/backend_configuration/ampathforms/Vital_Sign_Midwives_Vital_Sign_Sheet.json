            {
              "label": "Location:",
              "type": "encounterLocation",
              "required": "true",
              "questionOptions": {
                "rendering": "ui-select-extended"
              },
              "id": "encLocation"
            }
          ]
        }
      ]
    },
    {
      "label": "Vital Sign For Midwives",
      "sections": [
        {
          "label": "Vitals",
          "isExpanded": "true",
          "questions": [
            {
              "label": "WHO Date and Time",
              "type": "obs",
              "id": "midwivesDateTime",
              "datePickerFormat": "both",
              "questionOptions": {
                "rendering": "datetime",
                "concept": "162869AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
              }
            },
            {
              "label": "Pulse Rate",
              "type": "obs",
              "required": false,
              "id": "midwivesPulseRate",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0"
              },
              "questionInfo": "Normal range:00 bpm",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 100.5 || myValue < 59.5)",
                "message": "Pulse is out of range (Normal range 60-100)"
              }
            },
            {
              "label": "RR",
              "type": "obs",
              "required": false,
              "id": "midwivesRR",
              "questionOptions": {
                "concept": "5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number",
                "min": "0"
              },
              "questionInfo": "Normal range: 16-24 breaths/min",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 24.5 || myValue < 15.5)",
                "message": "Respiratory Rate is out of range (Normal range 16-24)"
              }
            },
            {
              "label": "Temperature",
              "type": "obs",
              "required": false,
              "id": "midwivesTemperature",
              "questionOptions": {
                "rendering": "number",
                "concept": "5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "25",
                "max": "43"
              },
              "questionInfo": "Normal range: 36.5-37.5°C",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 38.0 || myValue < 36.0)",
                "message": "Temperature is out of range (Normal range 36.5-37.5)"
              }
            },
            {
              "label": "Weight",
              "type": "obs",
              "required": false,
              "id": "midwivesWeight",
              "questionOptions": {
                "concept": "5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number"
              },
              "validators": []
            },
            {
              "label": "Total Fluid Inputs",
              "type": "obs",
              "required": false,
              "id": "midwivesFluidInputs",
              "questionOptions": {
                "concept": "163036AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number"
              }
            },
            {
              "label": "Total Fluid Outputs",
              "type": "obs",
              "required": false,
              "id": "midwivesFluidOutputs",
              "questionOptions": {
                "concept": "162659AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number"
              }
            },
            {
              "label": "Pain Score",
              "type": "obs",
              "required": true,
              "id": "midwivesPainScore",
              "questionOptions": {
                "rendering": "number",
                "concept": "166082AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
              },
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && myValue > 10",
                "message": "Pain score cannot exceed 10."
              }
            }
          ]
        }
      ]
    }
  ],
  "processor": "EncounterFormProcessor",
  "referencedForms": []
